#!/usr/bin/env bash

set -euo pipefail

router_home="${AI_ROUTER_HOME:-$HOME/.config/ai-coding-router}"
private_config="${AI_ROUTER_PRIVATE_CONFIG:-$router_home/providers.private.json}"
timeout_seconds="${AI_ROUTER_CHECK_TIMEOUT:-15}"
cache_ttl="${AI_ROUTER_CHECK_TTL:-120}"
cache_dir="${AI_ROUTER_STATUS_DIR:-$router_home/status}"
fresh=false

if [[ "${1:-}" == --fresh ]]; then
  fresh=true
  shift
fi

model_alias="${1:-}"
[[ -n "$model_alias" ]] || { printf 'Usage: router-check [--fresh] MODEL_ALIAS\n' >&2; exit 2; }

umask 077
mkdir -p "$cache_dir"
chmod 700 "$cache_dir"
cache_file="$cache_dir/${model_alias}.available"

cache_hit() {
  local route_id="$1" cached_at='' cached_id='' now
  [[ "$fresh" != true && -r "$cache_file" ]] || return 1
  {
    IFS= read -r cached_at
    IFS= read -r cached_id
  } < "$cache_file"
  [[ "$cached_at" =~ ^[0-9]+$ && "$cached_id" == "$route_id" ]] || return 1
  now=$(date +%s)
  ((now - cached_at < cache_ttl))
}

cache_store() {
  local route_id="$1" temp_file
  temp_file=$(mktemp "$cache_dir/.${model_alias}.XXXXXX")
  printf '%s\n%s\n' "$(date +%s)" "$route_id" > "$temp_file"
  chmod 600 "$temp_file"
  mv -f "$temp_file" "$cache_file"
}

if [[ "$model_alias" == codex || "$model_alias" == codex-high ]]; then
  if cache_hit 'codex-authenticated'; then
    printf 'AVAILABLE codex cached=true\n'
    exit 0
  fi
  command -v codex >/dev/null 2>&1 || { printf 'UNAVAILABLE codex command_missing\n' >&2; exit 1; }
  if codex login status 2>&1 | grep -q 'Logged in'; then
    cache_store 'codex-authenticated'
    printf 'AVAILABLE codex authenticated\n'
    exit 0
  fi
  printf 'UNAVAILABLE codex authentication\n' >&2
  exit 1
fi

command -v jq >/dev/null 2>&1 || { printf 'UNAVAILABLE jq command_missing\n' >&2; exit 1; }
command -v curl >/dev/null 2>&1 || { printf 'UNAVAILABLE curl command_missing\n' >&2; exit 1; }
[[ -r "$private_config" ]] || { printf 'UNAVAILABLE private_config unreadable\n' >&2; exit 1; }

case "$model_alias" in
  corporate-pro) provider='extra_litellm'; model_field='smart_model' ;;
  minimax) provider='minimax'; model_field='cheap_model' ;;
  cheap) provider='deepseek'; model_field='cheap_model' ;;
  openrouter-cheap) provider='openrouter'; model_field='cheap_model' ;;
  kimi-k3) provider='openrouter'; model_field='smart_model' ;;
  *) printf 'UNAVAILABLE unknown_alias=%s\n' "$model_alias" >&2; exit 2 ;;
esac

enabled=$(jq -r --arg provider "$provider" '.[$provider].enabled // false' "$private_config")
api_key=$(jq -r --arg provider "$provider" '.[$provider].api_key // ""' "$private_config")
base_url=$(jq -r --arg provider "$provider" '.[$provider].base_url // ""' "$private_config")
model=$(jq -r --arg provider "$provider" --arg field "$model_field" '.[$provider][$field] // ""' "$private_config")

[[ "$enabled" == true ]] || { printf 'UNAVAILABLE provider=%s disabled\n' "$provider" >&2; exit 1; }
[[ -n "$api_key" && "$api_key" != CHANGE_ME && -n "$base_url" && -n "$model" ]] || {
  printf 'UNAVAILABLE provider=%s incomplete_config\n' "$provider" >&2
  exit 1
}

route_id="$provider|$base_url|$model"
if cache_hit "$route_id"; then
  printf 'AVAILABLE provider=%s model=%s cached=true\n' "$provider" "$model"
  exit 0
fi

response_file=$(mktemp)
header_file=$(mktemp)
chmod 600 "$header_file"
printf 'Authorization: Bearer %s\nAccept: application/json\n' "$api_key" > "$header_file"
trap 'rm -f "$response_file" "$header_file"' EXIT
curl_network_args=()
host="${base_url#*://}"
host="${host%%/*}"
host="${host%%:*}"

if command -v scutil >/dev/null 2>&1 && command -v dig >/dev/null 2>&1; then
  split_dns_server=$(scutil --dns 2>/dev/null | awk -v target="$host" '
    /^resolver #/ { domain=""; nameserver="" }
    /^[[:space:]]+domain[[:space:]]+:/ { domain=$3 }
    /^[[:space:]]+nameserver\[0\][[:space:]]+:/ {
      nameserver=$3
      if (domain != "" && (target == domain || target ~ ("\\." domain "$"))) {
        print nameserver
        exit
      }
    }
  ')
  if [[ -n "$split_dns_server" ]]; then
    split_ip=$(dig +short @"$split_dns_server" "$host" A 2>/dev/null | awk '/^[0-9.]+$/ { print; exit }')
    [[ -n "$split_ip" ]] && curl_network_args+=(--resolve "$host:443:$split_ip")
  fi
fi

set +e
http_code=$(curl -sS --retry 1 --retry-all-errors --max-time "$timeout_seconds" \
  "${curl_network_args[@]}" \
  --output "$response_file" --write-out '%{http_code}' \
  --header "@$header_file" \
  "${base_url%/}/models" 2>/dev/null)
curl_status=$?
set -e

if ((curl_status != 0)); then
  printf 'UNAVAILABLE provider=%s transport=%d\n' "$provider" "$curl_status" >&2
  exit 1
fi
[[ "$http_code" == 200 ]] || { printf 'UNAVAILABLE provider=%s http=%s\n' "$provider" "$http_code" >&2; exit 1; }

if ! jq -e --arg model "$model" '[.data[]?.id] | index($model) != null' "$response_file" >/dev/null 2>&1; then
  printf 'UNAVAILABLE provider=%s model=%s missing\n' "$provider" "$model" >&2
  exit 1
fi

cache_store "$route_id"
printf 'AVAILABLE provider=%s model=%s\n' "$provider" "$model"
